{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HashSettings": {
    "Enabled": true,
    "Salt": "YourProductionSaltHere-CHANGE-ME",
    "MinHashLength": 6,
    "Alphabet": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890",
    "Separators": "cfhistuCFHISTU"
  }
}
